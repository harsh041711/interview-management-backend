# ====== Application ======
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
APP_NAME=Interview Management System

# Public origin used when issuing test links to candidates
# e.g. https://interviews.example.com (frontend), test path is appended
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ====== MongoDB ======
MONGODB_URI=mongodb://127.0.0.1:27017/interview_management

# ====== JWT (admin sessions) ======
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ====== Candidate test-token signing ======
TEST_TOKEN_SECRET=replace-with-a-long-random-string
TEST_LINK_EXPIRY_MINUTES=60
DEFAULT_TEST_DURATION_MINUTES=60

# ====== Admin Bootstrap ======
# Set to "true" once to allow /auth/register; turn off in production
ALLOW_ADMIN_REGISTER=true
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=harsh@topsinfosolutions.com
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_HR_EMAIL=harsh@topsinfosolutions.com

# ====== Cloudinary ======
CLOUDINARY_CLOUD_NAME=dhbmwxk1s
CLOUDINARY_API_KEY=634614344751325
CLOUDINARY_API_SECRET=Mh5f9EegzzZGpRF8asLCghq2nvU
CLOUDINARY_FOLDER=interview_management/candidates

# ====== AI Providers ======
# Gemini is tried first, with this internal fallback chain:
#   gemini-2.5-flash -> gemini-2.5-flash-lite -> gemini-2.0-flash -> gemini-2.0-flash-lite
# If the entire Gemini chain fails (rate limit / outage), we fall over to Groq:
#   llama-3.3-70b-versatile -> llama-3.1-8b-instant
GEMINI_API_KEY=<your-gemini-api-key>
GROQ_API_KEY=<your-groq-api-key>
AI_REQUEST_TIMEOUT_MS=15000

# ====== Email (Nodemailer SMTP) ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=harsh@topsinfosolutions.com
SMTP_PASSWORD=szhcopandqudnbvb
EMAIL_FROM="Interview Management <no-reply@example.com>"

# ====== Rate Limits ======
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# ====== Interviews ======
INTERVIEW_DEFAULT_DURATION_MINUTES=45
# Optional: dedicated HMAC secret for interview tokens.
# Leave blank to fall back to TEST_TOKEN_SECRET (recommended only in dev).
INTERVIEW_TOKEN_SECRET=
